# Optional: create a file named `.env` in the project root only if you want to
# override defaults or set a bearer token. You do NOT need `.env` to run the server
# without a bearer token—defaults work with no file.
# Used when you run: `pnpm run start:http` or `node dist/cli.js http`
# `pnpm run start:stdio` also loads `.env` if present (variables are optional for stdio).

# --- Streamable HTTP (public or remote server) ---
# Bind address. Use 127.0.0.1 for local only; 0.0.0.0 to listen on all interfaces (e.g. VPS).
# DIGIKALA_MCP_HTTP_HOST=127.0.0.1

# Port for the MCP HTTP endpoint
# DIGIKALA_MCP_HTTP_PORT=33445

# URL path for POST/GET/DELETE (must match the host app’s `url` in mcp.json)
# DIGIKALA_MCP_HTTP_PATH=/mcp

# Optional: require `Authorization: Bearer <token>` on every HTTP request.
# Set a long random secret in production. The same value must be sent by the MCP client (e.g. Cursor `headers`).
# DIGIKALA_MCP_HTTP_BEARER_TOKEN=

# --- Integration tests (optional) ---
# SKIP_INTEGRATION=1
